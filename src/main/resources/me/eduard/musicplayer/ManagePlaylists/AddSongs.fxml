<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Menu?>
<?import javafx.scene.control.MenuBar?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane fx:id="corePane" prefHeight="539.0" prefWidth="826.0" xmlns="http://javafx.com/javafx/22.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="me.eduard.musicplayer.Components.ManagePlaylist.AddSongs">
    <Label layoutX="12.0" layoutY="40.0" text="Input all youtube links to download the songs. Separate each link by &quot;,&quot;">
        <font>
          <Font size="24.0" />
        </font>
    </Label>
    <TextArea fx:id="textArea" layoutX="9.0" layoutY="81.0" prefHeight="347.0" prefWidth="812.0">
        <font>
            <Font size="14.0" />
        </font>
    </TextArea>
    <Button fx:id="proceedButton" layoutX="726.0" layoutY="502.0" mnemonicParsing="false" prefHeight="30.0" prefWidth="95.0" text="Update Playlist" />
    <Button fx:id="cancelButton" layoutX="618.0" layoutY="502.0" mnemonicParsing="false" prefHeight="30.0" prefWidth="95.0" text="Cancel" />
    <Label fx:id="statusLabel" alignment="CENTER" layoutX="12.0" layoutY="464.0" prefHeight="28.0" prefWidth="812.0" textFill="RED">
        <font>
          <Font size="19.0" />
        </font>
    </Label>
    <MenuBar layoutX="491.0" layoutY="502.0" prefHeight="26.0" prefWidth="112.0">
        <Menu mnemonicParsing="false" text="Video Quality...">
            <MenuItem fx:id="quality5" mnemonicParsing="false" text="1080p - High" />
            <MenuItem fx:id="quality4" mnemonicParsing="false" text="720p - Above-Medium" />
            <MenuItem fx:id="quality3" mnemonicParsing="false" text="480p - Medium" />
            <MenuItem fx:id="quality2" mnemonicParsing="false" text="360p - Low-Medium" />
            <MenuItem fx:id="quality1" mnemonicParsing="false" text="240p - Low" />
            <MenuItem fx:id="quality0" mnemonicParsing="false" text="144p - Lowest" />
        </Menu>
    </MenuBar>
    <Label fx:id="qualityLabel" alignment="CENTER" layoutX="9.0" layoutY="435.0" prefHeight="26.0" prefWidth="812.0" text="Getting default video quality">
        <font>
          <Font size="17.0" />
        </font>
    </Label>
   <MenuBar layoutX="369.0" layoutY="502.0">
      <menus>
         <Menu mnemonicParsing="false" text="Listening Mode">
            <items>
               <MenuItem fx:id="localDeviceMode" mnemonicParsing="false" text="Local Desktop Device" />
               <MenuItem fx:id="externalDeviceMode" mnemonicParsing="false" text="External Device" />
            </items>
         </Menu>
      </menus>
   </MenuBar>
   <CheckBox fx:id="audioOnly" layoutX="9.0" layoutY="505.0" mnemonicParsing="false" text="Prefer audio only">
      <font>
         <Font size="15.0" />
      </font>
   </CheckBox>
</AnchorPane>
